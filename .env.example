# Bright Data API key (scrape.py, scrape_download.py)
# Get from https://brightdata.com/cp/setting/users — do not commit real keys.
BRIGHTDATA_API_KEY=

# Optional: BRIGHT_DATA_API_KEY is also supported if you prefer that name.

# Optional: DB and Bright Data params
# LISTINGS_DB=listings.db
# BRIGHTDATA_DATASET_ID=gd_lvt9iwuh6fbcwmx1a
# BRIGHTDATA_KEYWORD=Apartment
# BRIGHTDATA_CITY=Provo, UT
# BRIGHTDATA_RADIUS_MILES=20
# BRIGHTDATA_LIMIT_PER_INPUT=100

# build_page.py: output directory and price filter
# BUILD_PAGE_OUTPUT=docs
# PRICE_MAX=2000
# PRICE_MIN=0

# Anthropic / Claude API key (scripts/extract_listing_prototype.py, Phase 2+)
# Get from https://console.anthropic.com/settings/keys — do not commit real keys.
ANTHROPIC_API_KEY=
