# Bright Data API key (scrape.py, scrape_download.py, fetch.py)
# Get from https://brightdata.com/cp/setting/users — do not commit real keys.
BRIGHT_DATA_API_KEY=

# Optional: used by fetch.py if set (fallback when BRIGHT_DATA_API_KEY not set)
# BRIGHT_DATA_FACEBOOK_MARKETPLACE_API_KEY=
# BRIGHTDATA_API_KEY=

# Optional: DB and Bright Data params
# LISTINGS_DB=listings.db
# BRIGHTDATA_DATASET_ID=gd_lvt9iwuh6fbcwmx1a
# BRIGHTDATA_KEYWORD=Apartment
# BRIGHTDATA_CITY=Provo, UT
# BRIGHTDATA_RADIUS_MILES=20
